# 知行 - 汉诺塔
# 经典递归问题：将圆盘从源柱移到目标柱

函 汉诺塔(甲, 乙, 丙, 丁) {
  若 甲 > 0 则 {
    汉诺塔(甲 - 1, 乙, 丁, 丙)
    打印(乙 + " -> " + 丁)
    汉诺塔(甲 - 1, 丙, 乙, 丁)
  }
}

打印("汉诺塔 3 层：")
汉诺塔(3, "A", "C", "B")

打印("")
打印("汉诺塔 4 层：")
汉诺塔(4, "A", "C", "B")
