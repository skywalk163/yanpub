# 言知 - 斐波那契数列
# 经典递归算法 + 模式匹配

# 递归版本
函数 斐波那契(甲) {
  如果 甲 < 2 那么 {
    返回 甲
  }
  返回 斐波那契(甲 - 1) + 斐波那契(甲 - 2)
}

# 模式匹配版本
函数 斐波那契匹配(甲) {
  匹配 甲 {
    情况 0 => 返回 0
    情况 1 => 返回 1
    情况 其他 => 返回 斐波那契匹配(甲 - 1) + 斐波那契匹配(甲 - 2)
  }
}

打印("递归: 斐波那契(10) = " + 斐波那契(10))
打印("匹配: 斐波那契匹配(10) = " + 斐波那契匹配(10))
