# 言知 - 冒泡排序
# 经典排序算法：相邻元素两两比较，大的往后换

函数 冒泡排序(甲) {
  定义 乙 = 长度(甲)
  循环当 乙 > 1 {
    定义 丙 = 0
    循环当 丙 < 乙 - 1 {
      如果 甲[丙] > 甲[丙 + 1] 那么 {
        定义 临时 = 甲[丙]
        甲[丙] = 甲[丙 + 1]
        甲[丙 + 1] = 临时
      }
      丙 = 丙 + 1
    }
    乙 = 乙 - 1
  }
  返回 甲
}

定义 数列 = [5, 3, 8, 1, 2, 9, 4, 7, 6]
打印("排序前：" + 数列)
打印("排序后：" + 冒泡排序(数列))
