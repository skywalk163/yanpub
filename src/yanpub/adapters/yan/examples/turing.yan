-- 言 - 图灵机原型机
-- 模拟二进制加一器：使用言语言双轨制(Python嵌入)

{{
tape = list("1011")
head = len(tape) - 1
carry = 1
while head >= 0 and carry:
    if tape[head] == "0":
        tape[head] = "1"
        carry = 0
    else:
        tape[head] = "0"
        carry = 1
    head -= 1
if carry:
    tape.insert(0, "1")
print("初始: 1011")
print("加一后: " + "".join(tape))
}}。
