-- 言 - 汉诺塔
-- 经典递归问题：使用言语言双轨制(Python嵌入)

{{
def hanoi(n, src, dst, aux):
    if n > 0:
        hanoi(n-1, src, aux, dst)
        print(f"移动圆盘从{src}到{dst}")
        hanoi(n-1, aux, dst, src)

print("汉诺塔 3 层：")
hanoi(3, "A", "C", "B")
}}。
