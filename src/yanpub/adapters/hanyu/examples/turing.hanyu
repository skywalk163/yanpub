# 翰语 - 图灵机原型机
# 模拟图灵机：二进制加一器

# 初始化纸带
定义吴tape=["1" "0" "1" "1" " "]
定义赵ptr=0
定义赵state=0
定义赵steps=0

打印("初始纸带：")
打印(吴tape)

# 简化的图灵机：二进制加一
# 从右往左扫描，遇到0变1停止，遇到1变0继续
定义赵pos=长度(吴tape)
赵pos=赵pos减1

循环当满赵pos大于等于0:
  定义赵val=吴tape[赵pos]
  如果赵val等于"0"那么:
    吴tape[赵pos]="1"
    赵pos=赵pos减1
    跳出
  否则:
    如果赵val等于"1"那么:
      吴tape[赵pos]="0"
    否则:
      吴tape[赵pos]="1"
      跳出
  赵pos=赵pos减1

打印("最终纸带：")
打印(吴tape)
