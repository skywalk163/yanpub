# 翰语 - 冒泡排序
# 经典排序算法：相邻元素两两比较，大的往后换

函数孙swap(孙lst, 孙i, 孙j):
  定义孙temp=孙lst[孙i]
  孙lst[孙i]=孙lst[孙j]
  孙lst[孙j]=孙temp

函数赵bubble(赵lst, 赵n):
  定义赵i=0
  循环当满赵i小于赵n:
    定义赵j=0
    循环当满赵j小于赵n减赵i减1:
      如果赵lst[赵j]大于赵lst[赵j加1]那么:
        孙swap(赵lst, 赵j, 赵j加1)
      赵j=赵j加1
    赵i=赵i加1

定义吴data=[5 3 8 1 2 9 4 7 6]
打印("排序前：")
打印(吴data)
赵bubble(吴data, 9)
打印("排序后：")
打印(吴data)
