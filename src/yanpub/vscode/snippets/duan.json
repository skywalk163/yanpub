{
    "段言-段落定义": {
        "prefix": "段落",
        "body": [
            "段落 ${1:名称}(${2:参数})。",
            "    ${3:// 函数体}",
            "    返回 ${4:结果}。",
            "结束。"
        ],
        "description": "定义一个段落（函数）"
    },
    "段言-变量声明": {
        "prefix": "设",
        "body": [
            "设 ${1:变量名} 为 ${2:值}。"
        ],
        "description": "声明变量：设甲为三"
    },
    "段言-条件语句": {
        "prefix": "如果",
        "body": [
            "如果 ${1:条件} 那么",
            "    ${2:// 执行体}",
            "否则",
            "    ${3:// 否则执行}",
            "结束。"
        ],
        "description": "条件语句：如果...那么...否则...结束"
    },
    "段言-当循环": {
        "prefix": "当",
        "body": [
            "当 ${1:条件}。",
            "    ${2:// 循环体}",
            "结束。"
        ],
        "description": "当循环：当条件...结束"
    },
    "段言-遍历循环": {
        "prefix": "遍历",
        "body": [
            "遍历 ${1:变量} 在 ${2:集合}。",
            "    ${3:// 循环体}",
            "结束。"
        ],
        "description": "遍历循环：遍历变量在集合"
    },
    "段言-类定义": {
        "prefix": "类",
        "body": [
            "类 ${1:类名}。",
            "    属性 ${2:属性名}。",
            "    构造 参数 ${3:参数名}。",
            "        己${2:属性名} 为 ${3:参数名}。",
            "    结束。",
            "结束。"
        ],
        "description": "类定义：类名、属性、构造函数"
    },
    "段言-类继承": {
        "prefix": "类继承",
        "body": [
            "类 ${1:子类} 继承 ${2:父类}。",
            "    ${3:// 类体}",
            "结束。"
        ],
        "description": "类继承定义"
    },
    "段言-尝试捕获": {
        "prefix": "尝试",
        "body": [
            "尝试：",
            "    ${1:// 尝试代码}",
            "捕获 ${2:异常变量}：",
            "    ${3:// 处理异常}",
            "结束。"
        ],
        "description": "异常处理：尝试...捕获...结束"
    },
    "段言-导入模块": {
        "prefix": "导入",
        "body": [
            "导入《${1:模块名}》。"
        ],
        "description": "导入模块"
    },
    "段言-从模块导入": {
        "prefix": "从导入",
        "body": [
            "从《${1:模块名}》导入 ${2:符号}。"
        ],
        "description": "从模块导入符号"
    },
    "段言-打印": {
        "prefix": "打印",
        "body": [
            "打印 ${1:\"内容\"}。"
        ],
        "description": "打印输出"
    },
    "段言-返回": {
        "prefix": "返回",
        "body": [
            "返回 ${1:值}。"
        ],
        "description": "返回值"
    },
    "段言-新建实例": {
        "prefix": "新建",
        "body": [
            "新建 ${1:类名} ${2:参数}。"
        ],
        "description": "创建类实例"
    }
}
