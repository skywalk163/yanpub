{
    "scopeName": "source.yanlv",
    "name": "言律 YanLv",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords-control" },
        { "include": "#keywords-define" },
        { "include": "#keywords-function" },
        { "include": "#keywords-exception" },
        { "include": "#keywords-module" },
        { "include": "#keywords-logic" },
        { "include": "#keywords-special" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [{ "name": "comment.line.number-sign.yanlv", "match": "#.*$" }]
        },
        "keywords-control": {
            "patterns": [
                { "name": "keyword.control.conditional.yanlv", "match": "如果|要是|否则|不然|否则如果|否则要是" },
                { "name": "keyword.control.loop.yanlv", "match": "当|一直|对于|遍历|每个|直到" },
                { "name": "keyword.control.flow.yanlv", "match": "返回|结束|循环" }
            ]
        },
        "keywords-define": {
            "patterns": [
                { "name": "keyword.declaration.yanlv", "match": "定|定义|设|设置|变量" }
            ]
        },
        "keywords-function": {
            "patterns": [
                { "name": "keyword.function.yanlv", "match": "函数|参数|调用" }
            ]
        },
        "keywords-exception": {
            "patterns": [
                { "name": "keyword.control.exception.yanlv", "match": "尝试|捕获|抛出|异常|最终" }
            ]
        },
        "keywords-module": {
            "patterns": [
                { "name": "keyword.control.import.yanlv", "match": "定义模块|导入|导出|从|作为|命名空间|结束模块" }
            ]
        },
        "keywords-logic": {
            "patterns": [
                { "name": "keyword.operator.logical.yanlv", "match": "且|或|非" }
            ]
        },
        "keywords-special": {
            "patterns": [
                { "name": "constant.language.yanlv", "match": "真|假|空" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.yanlv", "begin": "\"", "end": "\"", "patterns": [{ "name": "constant.character.escape.yanlv", "match": "\\\\." }] },
                { "name": "string.quoted.single.yanlv", "begin": "'", "end": "'", "patterns": [{ "name": "constant.character.escape.yanlv", "match": "\\\\." }] }
            ]
        },
        "numbers": {
            "patterns": [{ "name": "constant.numeric.yanlv", "match": "\\b\\d+(\\.\\d+)?\\b" }]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.arithmetic.yanlv", "match": "加|减|乘|除|余|等于|大于|小于|大于等于|小于等于|不等于" },
                { "name": "keyword.operator.comparison.yanlv", "match": "(==|!=|<=|>=|<|>)" },
                { "name": "keyword.operator.assignment.yanlv", "match": "=" }
            ]
        }
    }
}
