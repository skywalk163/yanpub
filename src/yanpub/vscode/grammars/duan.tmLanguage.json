{
    "scopeName": "source.duan",
    "name": "段言 Duan",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords-control" },
        { "include": "#keywords-define" },
        { "include": "#keywords-function" },
        { "include": "#keywords-class" },
        { "include": "#keywords-exception" },
        { "include": "#keywords-module" },
        { "include": "#keywords-logic" },
        { "include": "#keywords-special" },
        { "include": "#keywords-reserved" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#builtin-functions" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.duan",
                    "match": "#.*$"
                }
            ]
        },
        "keywords-control": {
            "patterns": [
                {
                    "name": "keyword.control.conditional.duan",
                    "match": "如果|那么|否则|否则若"
                },
                {
                    "name": "keyword.control.loop.duan",
                    "match": "当|遍历|在|跳出|跳过"
                },
                {
                    "name": "keyword.control.match.duan",
                    "match": "匹配|情况"
                }
            ]
        },
        "keywords-define": {
            "patterns": [
                {
                    "name": "keyword.declaration.duan",
                    "match": "设|定义|常量|类型|为"
                }
            ]
        },
        "keywords-function": {
            "patterns": [
                {
                    "name": "keyword.function.duan",
                    "match": "段落|段|参数|接收|返回|结束"
                }
            ]
        },
        "keywords-class": {
            "patterns": [
                {
                    "name": "keyword.declaration.class.duan",
                    "match": "类|继承|属性|构造|新建|接口|实现"
                }
            ]
        },
        "keywords-exception": {
            "patterns": [
                {
                    "name": "keyword.control.exception.duan",
                    "match": "尝试|捕获|抛出|最终"
                }
            ]
        },
        "keywords-module": {
            "patterns": [
                {
                    "name": "keyword.control.import.duan",
                    "match": "导入|从|导出|模块|标准库"
                }
            ]
        },
        "keywords-logic": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.duan",
                    "match": "且|或|非|与"
                }
            ]
        },
        "keywords-special": {
            "patterns": [
                {
                    "name": "constant.language.duan",
                    "match": "真|假|空"
                }
            ]
        },
        "keywords-reserved": {
            "patterns": [
                {
                    "name": "keyword.other.reserved.duan",
                    "match": "并|之|的|己|父|使用|标注|抽象"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.duan",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.duan",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.duan",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.duan",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.duan",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.duan",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.duan",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.duan",
                    "match": "="
                }
            ]
        },
        "builtin-functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.duan",
                    "match": "打印|长度|类型|输入|转换|排序|反转|合并|包含|查找|替换|分割|拼接|去除|大小写|编码|解码"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.duan",
                    "match": "。"
                },
                {
                    "name": "punctuation.separator.duan",
                    "match": "，|、"
                },
                {
                    "name": "punctuation.section.parens.duan",
                    "match": "[（)]"
                }
            ]
        }
    }
}
