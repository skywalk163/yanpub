{
    "scopeName": "source.yan",
    "name": "言 Yan",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords-define" },
        { "include": "#keywords-control" },
        { "include": "#keywords-function" },
        { "include": "#keywords-module" },
        { "include": "#keywords-io" },
        { "include": "#keywords-data" },
        { "include": "#keywords-operators" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.yan",
                    "match": "#.*$"
                }
            ]
        },
        "keywords-define": {
            "patterns": [
                {
                    "name": "keyword.declaration.yan",
                    "match": "定义|定|设|求值"
                }
            ]
        },
        "keywords-control": {
            "patterns": [
                {
                    "name": "keyword.control.conditional.yan",
                    "match": "如果|那么|否则|若"
                },
                {
                    "name": "keyword.control.loop.yan",
                    "match": "当|当时|遍历"
                }
            ]
        },
        "keywords-function": {
            "patterns": [
                {
                    "name": "keyword.function.yan",
                    "match": "函数|返回|结构|套|测"
                }
            ]
        },
        "keywords-module": {
            "patterns": [
                {
                    "name": "keyword.control.import.yan",
                    "match": "引|导|出"
                }
            ]
        },
        "keywords-io": {
            "patterns": [
                {
                    "name": "support.function.io.yan",
                    "match": "打印|印|印数|印浮|读|写|行|读行|输出"
                }
            ]
        },
        "keywords-data": {
            "patterns": [
                {
                    "name": "support.function.data.yan",
                    "match": "长|列|列表|连|添|含|首个|其余|入|反转|排序|映射|过滤|归约"
                }
            ]
        },
        "keywords-operators": {
            "patterns": [
                {
                    "name": "keyword.operator.word.yan",
                    "match": "加|减|乘|除|取"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.yan",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.yan",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.yan",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.yan",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.yan",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.yan",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.comparison.yan",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.yan",
                    "match": "="
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.yan",
                    "match": "。"
                },
                {
                    "name": "punctuation.separator.yan",
                    "match": "，|、"
                }
            ]
        }
    }
}
